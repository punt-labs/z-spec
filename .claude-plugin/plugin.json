{
  "name": "z-spec-dev",
  "description": "Create, validate, and test formal Z specifications for stateful systems using fuzz and probcli",
  "version": "0.10.0",
  "author": {
    "name": "Punt Labs",
    "email": "hello@punt-labs.com"
  },
  "mcpServers": {
    "zspec": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}", "z-spec", "mcp"],
      "env": {
        "ZSPEC_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
