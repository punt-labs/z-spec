# bd 1.0.x server-mode setup. Source of truth lives in central Hosted DoltDB,
# accessed via metadata.json + BEADS_DOLT_* env vars set by the org-root
# .envrc (in the punt-labs meta-repo) plus ~/.config/beads/server.json for TLS.
# Local-only files: never tracked.
#
# DO NOT add negation patterns (e.g. `!issues.jsonl`) here. Negations would
# re-enable tracking the auto-export views, which mix the central DB's state
# with this repo's git history and create merge conflicts on every bd write.
# The fork-protection rationale from older bd setups still applies.

# Auto-export views (regenerated locally on every bd write; not source of truth)
issues.jsonl
interactions.jsonl

# Embedded Dolt store (unused in server mode; left for legacy/rollback)
embeddeddolt/
backup/
*.corrupt.backup/
export-state.json
last-touched
.local_version

# Legacy SQLite cache files
db.sqlite
bd.db
*.db
*.db-journal
*.db-wal
*.db-shm

# Sync state (per-machine)
.sync.lock
sync_base.jsonl
redirect

# Merge artifacts
beads.base.jsonl
beads.base.meta.json
beads.left.jsonl
beads.left.meta.json
beads.right.jsonl
beads.right.meta.json

# Daemon runtime
daemon.lock
daemon.log
daemon.pid
bd.sock
sync-state.json
